#include <stdio.h>
#include <stdlib.h>

 int main (){
int num, soma = 0, count = 0;  
  
  printf("Digite numeros (digite um negativo para parar):\n");
  
  while(1){
  	scanf("%d", & num);
  	
  	if(num < 0)
  	break;
  	
  	soma += num;
  	count++;
  }

 if(count > 0){
 
     printf("\nmedia dos numeros: %.2f\n", (float)soma / count); 
} else{ 
     printf("\nnenhum numero positivo foi digitado.\n");
}

system("pause");

return 0;
}
  
